#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "SolidFI"
PROJECT_BRIEF          = "Functional Interfaces for Composition"
PROJECT_NUMBER         = "Draft"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include/solidfi README.md
FILE_PATTERNS          = *.hpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
STRIP_FROM_PATH        = include/

#---------------------------------------------------------------------------
# Extraction — document everything, spec is the source of truth
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_STATIC         = YES
ALWAYS_DETAILED_SEC    = YES
REPEAT_BRIEF           = YES
INHERIT_DOCS           = YES
HIDE_SCOPE_NAMES       = YES
HIDE_COMPOUND_REFERENCE = YES

#---------------------------------------------------------------------------
# Content display — Qt style: declaration order, no file noise
#---------------------------------------------------------------------------
BRIEF_MEMBER_DESC      = NO
SORT_MEMBER_DOCS       = NO
SORT_BRIEF_DOCS        = NO
SORT_BY_SCOPE_NAME     = NO
SHOW_INCLUDE_FILES     = NO
SHOW_GROUPED_MEMB_INC  = NO
INLINE_INHERITED_MEMB  = NO
FULL_PATH_NAMES        = NO
ALPHABETICAL_INDEX     = NO
SHOW_FILES             = NO
SHOW_NAMESPACES        = NO
BUILTIN_STL_SUPPORT    = YES
INLINE_INHERITED_MEMB  = YES

#---------------------------------------------------------------------------
# HTML — doxygen-awesome-css theme
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
CREATE_SUBDIRS         = NO
GENERATE_TREEVIEW      = NO
DISABLE_INDEX          = NO
HTML_EXTRA_STYLESHEET  = docs/doxygen-awesome.css
HTML_COLORSTYLE        = LIGHT
TREEVIEW_WIDTH         = 300
ENUM_VALUES_PER_LINE   = 1

#---------------------------------------------------------------------------
# Custom tags — spec lifecycle status
#---------------------------------------------------------------------------
ALIASES += proposed="@par Status: Proposed^^ Shape is defined; under review."
ALIASES += accepted="@par Status: Accepted^^ Spec is settled and stable."
ALIASES += reserved="@par Status: Reserved^^ Name is claimed; spec deliberately deferred."

#---------------------------------------------------------------------------
# No LaTeX, no other formats
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Diagrams — class hierarchy without graphviz
# Set HAVE_DOT = YES and install graphviz for richer diagrams
#---------------------------------------------------------------------------
HAVE_DOT               = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
